# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://autarkeia.world

# Stripe (add the same values in Vercel → Settings → Environment Variables)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=price_1TZdE7Lbszdp98VAHdPyhx57
STRIPE_PRICE_ANNUAL=price_1TZdIeLbszdp98VAyXIQyf56
STRIPE_WEBHOOK_SECRET=

# Resend (community interest + contact form emails)
RESEND_API_KEY=
# Contact form notifications (defaults to hello@autarkeia.world)
CONTACT_NOTIFY_EMAIL=hello@autarkeia.world

# Mapbox (public token for location autocomplete on /communities)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Amazon Associates (quiz email + marketplace affiliate links; defaults to autarkeia-es)
AMAZON_ASSOCIATES_TAG=autarkeia-es

# Awin product feeds (Toolbox → Create-a-Feed / Datafeed Builder API key — not Publisher API key)
AWIN_DATAFEED_API_KEY=
AWIN_PUBLISHER_ID=2900523

# Vercel Cron + manual sync auth (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
